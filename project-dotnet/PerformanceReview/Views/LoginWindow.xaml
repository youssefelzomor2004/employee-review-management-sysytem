<Window x:Class="PerformanceReview.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performance Review System" Width="500" Height="650"
        MinWidth="400" MinHeight="500" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <!-- Gradient Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f172a" Offset="0"/>
                <GradientStop Color="#1e1b4b" Offset="0.5"/>
                <GradientStop Color="#0f172a" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Login Card -->
        <Border Style="{StaticResource CardBorder}" MaxWidth="380" MaxHeight="520"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <!-- Logo -->
                <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Performance Review" Style="{StaticResource HeadingLabel}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to continue" Style="{StaticResource BodyLabel}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Username -->
                <TextBlock Text="Username" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource DarkTextBox}" Margin="0,0,0,16"/>

                <!-- Password -->
                <TextBlock Text="Password" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource DarkPasswordBox}" Margin="0,0,0,8"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Error Label -->
                <TextBlock x:Name="ErrorLabel" Foreground="{StaticResource DangerBrush}" FontSize="12"
                           Visibility="Collapsed" Margin="0,0,0,12"/>

                <!-- Login Button -->
                <Button Content="🔐  Sign In" Style="{StaticResource PrimaryButton}"
                        Click="LoginBtn_Click" Margin="0,8,0,12" HorizontalAlignment="Stretch"/>

                <!-- Register Link -->
                <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Hyperlink x:Name="RegisterLink" Click="RegisterLink_Click"
                               Foreground="{StaticResource PrimaryLightBrush}" FontSize="13">
                        Don't have an account? Register
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
