<Window x:Class="PerformanceReview.Views.EmployeeDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Dashboard - Performance Review System" Width="1000" Height="700"
        MinWidth="800" MinHeight="500" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="👤" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock x:Name="WelcomeLabel" Style="{StaticResource HeadingLabel}" FontSize="20"/>
                        <TextBlock x:Name="RoleLabel" Style="{StaticResource BodyLabel}"/>
                    </StackPanel>
                </StackPanel>
                <Button Content="🚪 Logout" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Right" Click="Logout_Click"/>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Style="{StaticResource DarkTabControl}">
            <!-- My Reviews Tab -->
            <TabItem Header="📝 My Reviews" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Reviews Received" Style="{StaticResource SubheadingLabel}" Margin="0,0,0,12"/>
                        <DataGrid Grid.Row="1" x:Name="MyReviewsGrid" Style="{StaticResource DarkDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Reviewer" Binding="{Binding Reviewer.Name}" Width="150"/>
                                <DataGridTextColumn Header="Punct" Binding="{Binding PunctualityScore}" Width="70"/>
                                <DataGridTextColumn Header="Team" Binding="{Binding TeamworkScore}" Width="70"/>
                                <DataGridTextColumn Header="Prod" Binding="{Binding ProductivityScore}" Width="70"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                <DataGridTextColumn Header="Comments" Binding="{Binding Comments}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="📥 Export Report" Style="{StaticResource PrimaryButton}" Click="ExportReport_Click" Padding="12,8"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- My Score Tab -->
            <TabItem Header="📊 My Score" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <TextBox x:Name="ScoreDisplay" Style="{StaticResource DarkTextBox}"
                             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="13"/>
                </Border>
            </TabItem>

            <!-- My Goals Tab -->
            <TabItem Header="🎯 Goals" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid Grid.Row="0" x:Name="GoalsGrid" Style="{StaticResource DarkDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                <DataGridTextColumn Header="Created" Binding="{Binding CreatedDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBox x:Name="NewGoalBox" Style="{StaticResource DarkTextBox}" Width="350" Margin="0,0,8,0"/>
                            <Button Content="➕ Add Goal" Style="{StaticResource PrimaryButton}" Click="AddGoal_Click" Padding="12,8" Margin="0,0,8,0"/>
                            <Button Content="✅ Complete" Style="{StaticResource SecondaryButton}" Click="CompleteGoal_Click" Padding="12,8"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Training Tab -->
            <TabItem Header="📚 Training" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <DataGrid x:Name="TrainingGrid" Style="{StaticResource DarkDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Course" Binding="{Binding CourseName}" Width="200"/>
                            <DataGridTextColumn Header="Recommended By" Binding="{Binding RecommenderName}" Width="150"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateRecommended, StringFormat=yyyy-MM-dd}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Peer Review Tab -->
            <TabItem Header="🤝 Peer Review" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Peer" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="PeerCombo" Style="{StaticResource DarkComboBox}" Width="200" DisplayMemberPath="Name"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Collab (1-5)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="PeerCollabBox" Style="{StaticResource DarkTextBox}" Width="60"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Comm (1-5)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="PeerCommBox" Style="{StaticResource DarkTextBox}" Width="60"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Team (1-5)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="PeerTeamBox" Style="{StaticResource DarkTextBox}" Width="60"/>
                            </StackPanel>
                            <Button Content="Submit" Style="{StaticResource PrimaryButton}" Click="SubmitPeerReview_Click"
                                    VerticalAlignment="Bottom" Padding="12,8"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="PeerReviewsGrid" Style="{StaticResource DarkDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Peer" Binding="{Binding Reviewed.Name}" Width="150"/>
                                <DataGridTextColumn Header="Collab" Binding="{Binding CollaborationScore}" Width="70"/>
                                <DataGridTextColumn Header="Comm" Binding="{Binding CommunicationScore}" Width="70"/>
                                <DataGridTextColumn Header="Team" Binding="{Binding TeamworkScore}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Upward Review Tab -->
            <TabItem Header="⬆️ Upward Review" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" x:Name="UpwardManagerLabel" Style="{StaticResource SubheadingLabel}" Margin="0,0,0,12"/>
                        <StackPanel Grid.Row="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Punct (1-5)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UpPunctBox" Style="{StaticResource DarkTextBox}" Width="60"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Team (1-5)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UpTeamBox" Style="{StaticResource DarkTextBox}" Width="60"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Prod (1-5)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="UpProdBox" Style="{StaticResource DarkTextBox}" Width="60"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBox x:Name="UpCommentsBox" Style="{StaticResource DarkTextBox}" Height="80"
                                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>
                            <Button Content="Submit Upward Review" Style="{StaticResource PrimaryButton}"
                                    Click="SubmitUpwardReview_Click" HorizontalAlignment="Left" Padding="16,10"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
