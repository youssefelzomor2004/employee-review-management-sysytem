<Window x:Class="PerformanceReview.Views.ManagerDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manager Dashboard - Performance Review System" Width="1100" Height="750"
        MinWidth="900" MinHeight="600" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="👔" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock x:Name="WelcomeLabel" Style="{StaticResource HeadingLabel}" FontSize="20"/>
                        <TextBlock x:Name="RoleLabel" Style="{StaticResource BodyLabel}"/>
                    </StackPanel>
                </StackPanel>
                <Button Content="🚪 Logout" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Right" Click="Logout_Click"/>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Style="{StaticResource DarkTabControl}">
            <!-- Team Tab -->
            <TabItem Header="👥 My Team" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Team Members" Style="{StaticResource SubheadingLabel}" Margin="0,0,0,12"/>
                        <DataGrid Grid.Row="1" x:Name="TeamGrid" Style="{StaticResource DarkDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="120"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="140"/>
                                <DataGridTextColumn Header="Tier" Binding="{Binding TierLevel}" Width="60"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Write Review Tab -->
            <TabItem Header="📝 Write Review" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Create Performance Review" Style="{StaticResource SubheadingLabel}" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Employee" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="ReviewEmployeeCombo" Style="{StaticResource DarkComboBox}" Width="200" DisplayMemberPath="Name"/>
                            </StackPanel>
                        </StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Punct (1-10)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="RevPunctBox" Style="{StaticResource DarkTextBox}" Width="70"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Team (1-10)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="RevTeamBox" Style="{StaticResource DarkTextBox}" Width="70"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <TextBlock Text="Prod (1-10)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="RevProdBox" Style="{StaticResource DarkTextBox}" Width="70"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <TextBlock Text="Leader (1-10)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="RevLeaderBox" Style="{StaticResource DarkTextBox}" Width="70"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="0,0,12,0">
                                <TextBlock Text="Vision (1-10)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="RevVisionBox" Style="{StaticResource DarkTextBox}" Width="70"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5">
                                <TextBlock Text="Mgmt (1-10)" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="RevMgmtBox" Style="{StaticResource DarkTextBox}" Width="70"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Comments" Style="{StaticResource BodyLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="RevCommentsBox" Style="{StaticResource DarkTextBox}" Height="80"
                                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>
                        <Button Content="Submit Review" Style="{StaticResource PrimaryButton}" Click="SubmitReview_Click"
                                HorizontalAlignment="Left" Padding="16,10"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Team Goals Tab -->
            <TabItem Header="🎯 Team Goals" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid Grid.Row="0" x:Name="TeamGoalsGrid" Style="{StaticResource DarkDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Employee" Binding="{Binding Employee.Name}" Width="150"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                            <ComboBox x:Name="GoalEmployeeCombo" Style="{StaticResource DarkComboBox}" Width="150"
                                      DisplayMemberPath="Name" Margin="0,0,8,0"/>
                            <TextBox x:Name="TeamGoalBox" Style="{StaticResource DarkTextBox}" Width="300" Margin="0,0,8,0"/>
                            <Button Content="➕ Assign Goal" Style="{StaticResource PrimaryButton}" Click="AssignTeamGoal_Click" Padding="12,8"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Training Tab -->
            <TabItem Header="📚 Training" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <ComboBox x:Name="TrainEmployeeCombo" Style="{StaticResource DarkComboBox}" Width="150"
                                      DisplayMemberPath="Name" Margin="0,0,8,0"/>
                            <ComboBox x:Name="TrainCourseCombo" Style="{StaticResource DarkComboBox}" Width="200" Margin="0,0,8,0"/>
                            <Button Content="Recommend" Style="{StaticResource PrimaryButton}" Click="RecommendTraining_Click" Padding="12,8"/>
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="TrainingRecsGrid" Style="{StaticResource DarkDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Employee" Binding="{Binding Recipient.Name}" Width="150"/>
                                <DataGridTextColumn Header="Course" Binding="{Binding CourseName}" Width="200"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Reports Tab -->
            <TabItem Header="📊 Reports" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="📈 Top Performers" Style="{StaticResource PrimaryButton}" Click="TopPerformers_Click" Margin="0,0,8,0" Padding="12,8"/>
                            <Button Content="📊 Skill Gap" Style="{StaticResource SecondaryButton}" Click="SkillGap_Click" Margin="0,0,8,0"/>
                            <Button Content="📋 Team Report" Style="{StaticResource SecondaryButton}" Click="TeamReport_Click" Margin="0,0,8,0"/>
                            <Button Content="📥 Export" Style="{StaticResource SecondaryButton}" Click="ExportTeamReport_Click"/>
                        </StackPanel>
                        <TextBox Grid.Row="1" x:Name="ReportDisplay" Style="{StaticResource DarkTextBox}"
                                 IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"/>
                    </Grid>
                </Border>
            </TabItem>

            <!-- My Score Tab -->
            <TabItem Header="📊 My Score" Style="{StaticResource DarkTabItem}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <TextBox x:Name="MyScoreDisplay" Style="{StaticResource DarkTextBox}"
                             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="13"/>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
